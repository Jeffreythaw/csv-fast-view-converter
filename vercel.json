{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/convert.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/convert",
      "destination": "/api/convert.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
